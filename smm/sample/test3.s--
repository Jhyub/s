(* was:
   fn (x, y, z, w) =>
       let g := if w = 0 then fn (a) => a + y
                         else fn (b) => b + z in
       let p := 1 in
       g(x) + g(x) + g(p)
   A function can no longer be the value of an if-branch (functions are not
   values), so the branch is folded into g's own body instead.
   run with x=3, y=10, z=100, w=0 *)
let x := 3 in
let y := 10 in
let z := 100 in
let w := 0 in
let fn g(a, w, y, z) => if w = 0 then a + y else a + z in
let p := 1 in
g(x, w, y, z) + g(x, w, y, z) + g(p, w, y, z)